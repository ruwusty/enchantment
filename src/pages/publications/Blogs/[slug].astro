---
import { getCollection, render } from 'astro:content';
import Container from '../../../components/Container.astro';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blogs', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={`${post.data.title} — DataSoc`}>
  {post.data.coverImage && (
    <div class="w-full h-64 md:h-96 overflow-hidden">
      <img
        src={post.data.coverImage}
        alt={post.data.title}
        class="w-full h-full object-cover"
      />
    </div>
  )}

  <Container class="py-10 max-w-3xl">
    <a
      href="/publications/Blogs"
      class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-[#134f5c] transition-colors mb-8"
    >
      ← Back to Blogs
    </a>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.tags.map(tag => (
          <span class="text-xs px-2 py-1 bg-[#ffebe1] text-[#134f5c] rounded-full font-medium">
            {tag}
          </span>
        ))}
      </div>
    )}

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 leading-tight">
      {post.data.title}
    </h1>
    <p class="text-lg text-gray-500 mb-6">{post.data.description}</p>

    <div class="flex items-center gap-3 pb-6 border-b border-gray-100 mb-8">
      <div class="w-9 h-9 rounded-full bg-[#134f5c] flex items-center justify-center text-white text-sm font-bold shrink-0">
        {post.data.author.charAt(0)}
      </div>
      <div>
        <p class="text-sm font-medium text-gray-800">{post.data.author}</p>
        <p class="text-xs text-gray-400">{formatDate(post.data.date)}</p>
      </div>
    </div>

    <div class="prose">
      <Content />
    </div>
  </Container>
</Layout>

<style>
  .prose :global(p) {
    color: #374151;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(ul) {
    list-style-type: disc;
    list-style-position: inside;
    margin-bottom: 1.25rem;
    color: #374151;
  }
  .prose :global(ol) {
    list-style-type: decimal;
    list-style-position: inside;
    margin-bottom: 1.25rem;
    color: #374151;
  }
  .prose :global(li) {
    margin-bottom: 0.25rem;
  }
  .prose :global(a) {
    color: #134f5c;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) {
    color: #0d3840;
  }
  .prose :global(strong) {
    font-weight: 600;
    color: #111827;
  }
  .prose :global(em) {
    font-style: italic;
  }
  .prose :global(code) {
    background-color: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: monospace;
    color: #1f2937;
  }
  .prose :global(pre) {
    background-color: #111827;
    color: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
  }
  .prose :global(pre code) {
    background-color: transparent;
    padding: 0;
  }
  .prose :global(blockquote) {
    border-left: 4px solid #ffcd95;
    padding-left: 1.25rem;
    font-style: italic;
    color: #6b7280;
    margin: 1.5rem 0;
  }
  .prose :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem auto;
    max-width: 100%;
  }
  .prose :global(hr) {
    border-color: #e5e7eb;
    margin: 2rem 0;
  }
</style>
