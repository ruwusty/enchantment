---
import Container from '../../components/Container.astro';
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Who We Are - UNSW Data Science Society">
    <Header>
        <h1>Who We Are</h1>
        <p>Meet the people behind UNSW DataSoc.</p>
    </Header>

    <Container class="space-y-12 py-6 max-w-6xl">

        <!-- PRESIDENT -->
        <section class="space-y-6 text-center">
            <h2 class="text-2xl font-bold">President</h2>

            <div class="flex justify-center">
                <div class="w-[60%] md:w-[30%] lg:w-[22%]">
                    <img src="/who-we-are/datasoc-board-photos/P1025432.JPG"
                         class="w-full h-80 object-cover rounded-lg" />
                    <p class="mt-2 font-semibold">Qingyuan He</p>
                    <p class="text-sm text-gray-600">President</p>
                </div>
            </div>
        </section>

        <!-- VICE PRESIDENTS -->
        <section class="space-y-6">
            <h2 class="text-2xl font-bold text-center">Vice Presidents</h2>

            <div class="flex flex-wrap justify-center gap-6">
                <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                    <img src="/who-we-are/datasoc-board-photos/P1025327.JPG"
                         class="w-full h-80 object-cover rounded-lg" />
                    <p class="mt-2 font-semibold">Stella Lin</p>
                    <p class="text-sm text-gray-600">VP (Development)</p>
                </div>

                <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                    <img src="/who-we-are/datasoc-board-photos/P1025394.JPG"
                         class="w-full h-80 object-cover rounded-lg" />
                    <p class="mt-2 font-semibold">Ethan Pham</p>
                    <p class="text-sm text-gray-600">VP (Activities)</p>
                </div>

                <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                    <img src="/who-we-are/datasoc-board-photos/P1025414.JPG"
                         class="w-full h-80 object-cover rounded-lg" />
                    <p class="mt-2 font-semibold">Andre Baruah</p>
                    <p class="text-sm text-gray-600">VP (Operations)</p>
                </div>
            </div>
        </section>

        <!-- SECRETARY -->
        <section class="space-y-6 text-center">
            <h2 class="text-2xl font-bold">Secretary</h2>

            <div class="flex justify-center">
                <div class="w-[60%] md:w-[30%] lg:w-[22%]">
                    <img src="/who-we-are/datasoc-board-photos/P1025418.JPG"
                         class="w-full h-80 object-cover rounded-lg" />
                    <p class="mt-2 font-semibold">Akhil Panwar</p>
                    <p class="text-sm text-gray-600">Secretary</p>
                </div>
            </div>
        </section>

        <!-- DIRECTORS -->
        <section class="space-y-10">
            <h2 class="text-2xl font-bold text-center">Directors</h2>

            <!-- TECHNOLOGY -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Technology</h3>
                <div class="flex flex-wrap justify-center gap-6">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025398.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Kai Lu</p>
                        <p class="text-sm text-gray-600">Technology Director</p>
                    </div>

                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025410.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Shafquat Tabeeb</p>
                        <p class="text-sm text-gray-600">Technology Director</p>
                    </div>
                </div>
            </div>

            <!-- MEDIA -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Media</h3>
                <div class="flex flex-wrap justify-center gap-6">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025344.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Shreya Verma</p>
                        <p class="text-sm text-gray-600">Media Director</p>
                    </div>

                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025429.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Vedant Tyagi</p>
                        <p class="text-sm text-gray-600">Media Director</p>
                    </div>
                </div>
            </div>

            <!-- EDUCATION -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Education</h3>
                <div class="flex flex-wrap justify-center gap-6">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025422.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Minjun Kim</p>
                        <p class="text-sm text-gray-600">Education Director</p>
                    </div>

                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025425.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Lily Tang</p>
                        <p class="text-sm text-gray-600">Education Director</p>
                    </div>
                </div>
            </div>

            <!-- CAREERS -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Careers</h3>
                <div class="flex justify-center">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025385.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Vidisha Trivedi</p>
                        <p class="text-sm text-gray-600">Careers Director</p>
                    </div>
                </div>
            </div>

            <!-- HUMAN RESOURCES -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Human Resources</h3>
                <div class="flex justify-center">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025389.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Yatha Shah</p>
                        <p class="text-sm text-gray-600">HR Director</p>
                    </div>
                </div>
            </div>

            <!-- PHILANTHROPY & PROJECTS -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Philanthropy & Projects</h3>
                <div class="flex flex-wrap justify-center gap-6">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025390.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Anoushka Pandey</p>
                        <p class="text-sm text-gray-600">Philanthropy & Projects Director</p>
                    </div>

                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025419.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Isabella Fan</p>
                        <p class="text-sm text-gray-600">Philanthropy & Projects Director</p>
                    </div>
                </div>
            </div>

            <!-- SOCIALS -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Socials</h3>
                <div class="flex justify-center">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025438.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Linh Pham</p>
                        <p class="text-sm text-gray-600">Socials Director</p>
                    </div>
                </div>
            </div>

            <!-- SPONSORSHIPS -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-center">Sponsorships</h3>
                <div class="flex justify-center">
                    <div class="w-[45%] md:w-[30%] lg:w-[22%] text-center">
                        <img src="/who-we-are/datasoc-board-photos/P1025443.JPG" class="w-full h-80 object-cover rounded-lg" />
                        <p class="mt-2 font-semibold">Cathy Dinh</p>
                        <p class="text-sm text-gray-600">Sponsorships Director</p>
                    </div>
                </div>
            </div>

        </section>

    </Container>
</Layout>
