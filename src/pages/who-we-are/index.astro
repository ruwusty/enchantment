---
import Container from '../../components/Container.astro';
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Who We Are - UNSW Data Science Society">
    <Header>
        <h1>Who We Are</h1>
        <p>Meet the people behind UNSW DataSoc.</p>
    </Header>

    <Container class="space-y-16 py-6 max-w-6xl">
        <!-- PRESIDENT -->
        <section class="space-y-6 text-center">
            <h2 class="text-2xl font-bold">President</h2>

            <div class="flex justify-center">
                <div class="w-[70%] sm:w-[50%] md:w-[32%] lg:w-[24%] text-center">
                    <img
                        src="/who-we-are/datasoc-board-photos/P1025432.JPG"
                        alt="Qingyuan He"
                        class="w-full h-80 object-cover rounded-lg"
                    />
                    <p class="mt-3 font-semibold">Qingyuan He</p>
                    <p class="text-sm text-gray-600">President</p>
                </div>
            </div>
        </section>

        <!-- EXECUTIVES -->
        <section class="space-y-6">
            <h2 class="text-2xl font-bold text-center">Executives</h2>

            <div class="flex flex-wrap justify-center gap-8">
                <div class="w-[42%] sm:w-[38%] md:w-[28%] lg:w-[22%] text-center">
                    <img
                        src="/who-we-are/datasoc-board-photos/P1025394.JPG"
                        alt="Ethan Pham"
                        class="w-full h-80 object-cover rounded-lg"
                    />
                    <p class="mt-3 font-semibold">Ethan Pham</p>
                    <p class="text-sm text-gray-600">Vice President (Activities)</p>
                </div>

                <div class="w-[42%] sm:w-[38%] md:w-[28%] lg:w-[22%] text-center">
                    <img
                        src="/who-we-are/datasoc-board-photos/P1025327.JPG"
                        alt="Stella Lin"
                        class="w-full h-80 object-cover rounded-lg"
                    />
                    <p class="mt-3 font-semibold">Stella Lin</p>
                    <p class="text-sm text-gray-600">Vice President (Development)</p>
                </div>

                <div class="w-[42%] sm:w-[38%] md:w-[28%] lg:w-[22%] text-center">
                    <div class="w-full h-80 rounded-lg border border-gray-200 bg-gray-50 flex items-center justify-center">
                        <span class="text-sm text-gray-400">Photo unavailable</span>
                    </div>
                    <p class="mt-3 font-semibold">Naisha Kulshreshtha</p>
