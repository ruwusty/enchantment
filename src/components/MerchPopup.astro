---
// MerchPopup component
---

<div
  id="merch-popup"
  class="fixed inset-0 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
>
  <div class="bg-white rounded-2xl shadow-xl w-full max-w-[90vw] sm:max-w-[520px] md:max-w-[640px] lg:max-w-[720px] xl:max-w-2xl max-h-[80vh] sm:max-h-[85vh] overflow-hidden relative flex flex-col md:flex-row transition-all duration-200 merch-popup-card">
    <!-- Close button -->
    <button
      id="close-popup"
      class="absolute top-3 right-3 p-2 text-black hover:text-gray-600 z-10 cursor-pointer rounded-full bg-white/80 backdrop-blur-sm border border-black/5"
      aria-label="Close merch popup"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    
    <div class="flex flex-col md:flex-row h-full">
      <!-- Left side - Image -->
      <div class="md:w-1/2 merch-popup-image">
        <img 
          src="/images/merch_popup.jpg" 
          alt="DataSoc Merch" 
          class="w-full h-48 sm:h-64 md:h-full object-cover"
        />
      </div>
      
      <!-- Right side - Content -->
      <div class="md:w-1/2 bg-gray-50 p-5 sm:p-8 flex flex-col justify-center overflow-y-auto gap-4 sm:gap-6 merch-popup-content">
        <div class="text-center flex flex-col gap-4 sm:gap-6 merch-popup-inner">
          <!-- Headline -->
          <h2 class="text-[clamp(1.5rem,1vw+1.2rem,2.2rem)] leading-tight font-bold" style="font-family: 'Lexend', sans-serif;">
            <span class="text-black">merch has </span>
            <span style="color: #b41c27;">arrived!</span>
          </h2>
          
          <!-- Sub-text -->
          <p class="text-gray-700 text-[clamp(1rem,0.7vw+0.95rem,1.25rem)]" style="font-family: 'Lexend', sans-serif;">
            check out our new collection of hoodies, t-shirts, and stickers
          </p>
          
          <!-- Call to action button -->
          <a 
            href="/merch" 
            id="lets-go-btn"
            class="inline-block bg-black text-white font-bold py-3 px-8 sm:px-10 text-base sm:text-lg rounded-lg hover:bg-gray-800 hover:scale-105 hover:shadow-lg transition-all duration-200 w-full max-w-xs sm:max-w-sm transform active:scale-95 mx-auto"
            style="font-family: 'Lexend', sans-serif;"
          >
            let's go!
          </a>
          
          <!-- Dismissal link -->
          <button 
            id="no-thanks" 
            class="block mx-auto text-black underline hover:text-gray-600 transition-colors duration-200 cursor-pointer"
            style="font-family: 'Lexend', sans-serif;"
          >
            no thanks
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const popup = document.getElementById('merch-popup');
    const closeBtn = document.getElementById('close-popup');
    const noThanksBtn = document.getElementById('no-thanks');
    const letsGoBtn = document.getElementById('lets-go-btn');
    
    // Check if elements exist
    if (!popup || !closeBtn || !noThanksBtn) {
      console.error('Merch popup: required elements not found');
      return;
    }
    
    // Check if popup has been shown before
    const hasSeenPopup = sessionStorage.getItem('merch-popup-shown');
    
    // Only show popup if it hasn't been shown before and we're on the home page
    if (!hasSeenPopup && window.location.pathname === '/') {
      setTimeout(() => {
        popup.classList.remove('hidden');
        popup.classList.add('flex');
      }, 1000);
    }
    
    // Close popup function
    function closePopup() {
      if (popup) {
        popup.classList.add('hidden');
        popup.classList.remove('flex');
        sessionStorage.setItem('merch-popup-shown', 'true');
      }
    }
    
    // Close button click
    closeBtn.addEventListener('click', closePopup);
    
    // No thanks button click
    noThanksBtn.addEventListener('click', closePopup);
    
    // Let's go button click animation
    if (letsGoBtn) {
      letsGoBtn.addEventListener('click', function(e) {
        // Add click animation
        this.style.transform = 'scale(0.95)';
        this.style.backgroundColor = '#374151'; // Darker gray
        
        // Reset after animation
        setTimeout(() => {
          this.style.transform = '';
          this.style.backgroundColor = '';
        }, 150);
      });
    }
    
    // Click outside popup to close
    popup.addEventListener('click', function(e) {
      if (e.target === popup) {
        closePopup();
      }
    });
    
    // Escape key to close
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && popup && popup.style.display !== 'none') {
        closePopup();
      }
    });
  });
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap');

  /* Extra-small viewport handling (short windows on desktop/laptops) */
  @media (max-height: 550px) {
    #merch-popup .merch-popup-card {
      max-height: 95vh;
      border-radius: 0.9rem;
    }

    #merch-popup .merch-popup-image img {
      height: 32vh;
      object-position: top;
    }

    #merch-popup .merch-popup-content {
      padding: 0.75rem 1rem;
      gap: 0.75rem;
    }

    #merch-popup .merch-popup-inner h2 {
      font-size: 1.25rem;
    }

    #merch-popup .merch-popup-inner p {
      font-size: 0.9rem;
    }

    #merch-popup .merch-popup-inner #lets-go-btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.95rem;
    }
  }

  /* Ultra-small viewports (very short or very narrow) */
  @media (max-height: 450px), (max-width: 320px) {
    #merch-popup .merch-popup-card {
      max-height: 92vh;
      max-width: 88vw;
      border-radius: 0.8rem;
    }

    #merch-popup .merch-popup-image img {
      height: 26vh;
      object-position: top;
    }

    #merch-popup .merch-popup-content {
      padding: 0.6rem 0.85rem;
      gap: 0.6rem;
      max-height: 52vh;
    }

    #merch-popup .merch-popup-inner h2 {
      font-size: 1.1rem;
    }

    #merch-popup .merch-popup-inner p {
      font-size: 0.85rem;
    }

    #merch-popup .merch-popup-inner #lets-go-btn {
      padding: 0.45rem 0.65rem;
      font-size: 0.9rem;
    }

    #merch-popup #no-thanks {
      font-size: 0.85rem;
      margin-top: 0.25rem;
    }
  }
</style> 