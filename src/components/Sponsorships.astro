      <style>
        /* Scroll-in animation for each tier block */
        [data-tier] {
          opacity: 0;
          transform: translateY(18px) scale(0.98);
          transition: opacity 700ms ease, transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
          will-change: opacity, transform;
        }

        [data-tier].tier-visible {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      </style>

      <script is:inline>
        (() => {
          const tierEls = document.querySelectorAll('[data-tier]');
          if (!tierEls.length) return;

          // If a tier is already visible on first render, reveal it immediately.
          tierEls.forEach((el) => {
            const rect = el.getBoundingClientRect();
            const inViewport = rect.top < window.innerHeight && rect.bottom > 0;
            if (inViewport) el.classList.add('tier-visible');
          });

          if (!('IntersectionObserver' in window)) {
            tierEls.forEach((el) => el.classList.add('tier-visible'));
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (!entry.isIntersecting) continue;
                entry.target.classList.add('tier-visible');
                observer.unobserve(entry.target);
              }
            },
            // Low threshold so small sections (like single-logo Gold) still trigger.
            { threshold: 0.01, rootMargin: '0px 0px -5% 0px' }
          );

          tierEls.forEach((el) => {
            if (!el.classList.contains('tier-visible')) observer.observe(el);
          });
        })();
      </script>
