          transition: transform 300ms ease-in-out;
        }

        .sponsor-slot:hover .sponsor-logo {
          transform: scale(1.05);
        }

      .logo-atlassian {
        max-width: none;
        max-height: none;
        width: 300px;
        height: auto;
      }

      .logo-janestreet {
        max-width: none;
